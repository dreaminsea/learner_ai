{
  "name": "learner_ai",
  "version": "1.0.0",
  "description": "LLM-driven learning application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/main/persistence/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "pack:mac": "npm run build && electron-builder --mac --arm64",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:all": "npm run build && electron-builder --mac --arm64 --win --x64"
  },
  "build": {
    "appId": "com.learnerai.app",
    "productName": "Learner_AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist",
        "to": "sql.js",
        "filter": [
          "*.wasm"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "@types/sql.js": "^1.4.11",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "openai": "^6.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.17.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreaminsea/learner_ai.git"
  },
  "author": "dreaminsea",
  "license": "ISC"
}
